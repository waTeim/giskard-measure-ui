# Runtime configuration (consumed by server.js).
# Copy to .env for local docker-compose / `docker run --env-file`.

# TCP port the server listens on (container-internal).
PORT=8080

# Upstream giskard-measure base URL. If unset, the proxy returns 502 and the
# UI runs in its built-in simulation fallback (still looks alive).
GISKARD_API_BASE=http://localhost:8000

# Upstream request timeout in milliseconds.
GISKARD_API_TIMEOUT_MS=5000

# Client poll cadence injected into the page (milliseconds).
METRICS_POLL_MS=3000
LIVE_POLL_MS=5000

# Optional label surfaced on /healthz and to the UI.
INSTANCE_LABEL=
