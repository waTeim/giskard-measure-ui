# Example local Helm values for `make helm-install`.
#
#   cp values.example.yaml values.local.yaml   # then edit
#   make helm-install                          # helm upgrade --install -f values.local.yaml
#
# Only deployment-specific overrides belong here — chart/values.yaml holds the full
# set of defaults. The image repository/tag are supplied by the Makefile
# (REGISTRY / VERSION, or VERSION-SPEC) at install time, so they are omitted here.
# Keep values.local.yaml out of version control.

# Runtime config — the specialization knobs from Dockerfile.spec, exposed as values.
config:
  # Upstream giskard-measure API this instance reverse-proxies (in-cluster service URL).
  giskardApiBase: "http://giskard-measure:8000"
  # Label surfaced on /healthz and to the UI; identifies this environment.
  instanceLabel: "prod-us-east"
  # Poll cadence / timeout (ms) — defaults (3000 / 5000 / 5000) are usually fine.
  # metricsPollMs: 3000
  # livePollMs: 5000
  # giskardApiTimeoutMs: 5000

# Public hostname + TLS. cert-manager (the "letsencrypt" ClusterIssuer) issues the cert.
ingress:
  hosts:
    - host: giskard-measure-ui.example.com
      paths:
        - path: /
          pathType: Prefix
  tls:
    - secretName: giskard-measure-ui-tls
      hosts:
        - giskard-measure-ui.example.com

# Uncomment to run more than one replica.
# replicaCount: 2
