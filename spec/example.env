# Example specialization config.
# Copy to spec/<name>.env and edit, then:  make specialization SPEC=<name>
#
# Each KEY=VALUE line is baked into the image as an ENV via --build-arg.
# Lines starting with # and blank lines are ignored.

# Upstream giskard-measure API this instance talks to (required for live data).
GISKARD_API_BASE=http://giskard-measure.prod.svc.cluster.local:8000

# Per-instance label surfaced on /healthz and to the UI runtime.
INSTANCE_LABEL=prod-us-east

# Poll cadence (ms). Defaults match the brief: metrics ~3s, live ~5s.
METRICS_POLL_MS=3000
LIVE_POLL_MS=5000

# Upstream request timeout (ms).
GISKARD_API_TIMEOUT_MS=5000
